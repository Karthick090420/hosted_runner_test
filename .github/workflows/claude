#!/usr/bin/env bash
set -e

if [ "$1" != "-p" ] || [ -z "$2" ]; then
  echo "Usage: claude -p <file>"
  exit 1
fi

FILE="$2"
CONTENT=$(cat "$FILE")

aws bedrock-runtime invoke-model \
  --model-id anthropic.claude-3-5-sonnet-20240620-v1:0 \
  --body "{\"messages\":[{\"role\":\"user\",\"content\":\"$CONTENT\"}],\"max_tokens\":500}" \
  --content-type application/json \
  --accept application/json \
  output.json

cat output.json
